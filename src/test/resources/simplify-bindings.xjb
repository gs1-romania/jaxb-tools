<?xml version="1.0" encoding="UTF-8"?>
<jaxb:bindings version="3.0"
               xmlns:jaxb="https://jakarta.ee/xml/ns/jaxb"
               xmlns:xs="http://www.w3.org/2001/XMLSchema"
               xmlns:simplify="http://jaxb-tools.gs1.ro/simplify">

    <jaxb:bindings schemaLocation="test.xsd" node="/xs:schema">
        <jaxb:bindings node="xs:complexType[@name='ContainerType']">
            <simplify:replaceGenericList field="item">java.lang.Number</simplify:replaceGenericList>
        </jaxb:bindings>
    </jaxb:bindings>

</jaxb:bindings>